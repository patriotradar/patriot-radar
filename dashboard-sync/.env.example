# Copy to .env.local for local `vercel dev` testing.
# In production, set these in the Vercel dashboard (Settings → Environment Variables).

# Google Trends snapshot for /api/trend-intelligence
TRENDS_JSON_URL=https://raw.githubusercontent.com/patriotradar/patriot-radar-dashboard/main/results.json

# Optional: hourly cron auth for /api/trend-intelligence refresh
CRON_SECRET=

# Supabase (required for auth + TikTok trend_intelligence_feed reads)
NEXT_PUBLIC_SUPABASE_URL=https://kdwqnlgdanzigpdwyqbh.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Legacy aliases also supported by /api/public-config.js
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Gemini chat proxy
GROQ_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
ALLOWED_ORIGIN=*
