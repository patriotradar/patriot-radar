# Optional: Google Trends snapshot URL for /api/trend-intelligence
TRENDS_JSON_URL=https://raw.githubusercontent.com/patriotradar/patriot-radar-dashboard/main/results.json

# Optional: authorize hourly cron refresh for /api/trend-intelligence
CRON_SECRET=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Vercel dashboard public Supabase client (also used by /api/public-config.js)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_ANON_KEY=

# Optional: direct Postgres URL to auto-apply trend_intelligence_feed schema in CI
SUPABASE_DB_URL=

# Apify TikTok scraper (required for live TikTok fetch in GitHub Actions / CLI)
APIFY_API_TOKEN=

# AI proxy endpoints (/api/chat/completions, /api/generate-post)
GROQ_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
ALLOWED_ORIGIN=*

# Optional Apify overrides
APIFY_TIKTOK_ACTOR_ID=clockworks/tiktok-scraper
APIFY_TIKTOK_CONFIG_PATH=data/apify_tiktok_config.json
TIKTOK_APIFY_HASHTAGS=britishpride,patriotism,ukpolitics,britishhistory,england
TIKTOK_APIFY_SEARCH_QUERIES=British pride TikTok|patriotism UK debate|British veterans respect
TIKTOK_APIFY_RESULTS_PER_PAGE=10

# Optional Supabase table override
SUPABASE_FEED_TABLE=trend_intelligence_feed

# Autonomous viral loop (queue-only by default; set AUTO_POST=true to enable posting eligibility)
AUTO_POST=false
CONTENT_QUEUE_TABLE=content_queue
CONTENT_PERFORMANCE_TABLE=content_performance
CONTENT_STRATEGY_TABLE=content_strategy_weights
AUTOMATION_SETTINGS_TABLE=automation_settings

# Niche Comment Intelligence (isolated raw comment ingest)
NICHE_COMMENT_RAW_TABLE=niche_comment_raw
NICHE_COMMENT_INGEST_CONFIG_PATH=data/niche_comment_ingest_config.json
APIFY_TIKTOK_COMMENT_ACTOR_ID=clockworks/tiktok-comments-scraper
APIFY_TIKTOK_COMMENTS_FALLBACK_ACTOR_ID=clockworks/tiktok-scraper
NICHE_COMMENT_COMMENTS_PER_POST=50
NICHE_COMMENT_MAX_VIDEOS=15

# Niche-Aware Comment Signals (isolated pipeline — does not affect trend_intelligence_feed)
SUPABASE_NICHE_COMMENT_TABLE=niche_comment_signals_feed
NICHE_COMMENT_CONFIG_PATH=data/niche_comment_config.json
APIFY_TIKTOK_COMMENTS_ACTOR_ID=clockworks/tiktok-scraper
TIKTOK_APIFY_COMMENTS_PER_POST=30
# Optional comma-separated overrides for niche keyword matching
# NICHE_COMMENT_KEYWORDS=british,patriotism,history
# NICHE_COMMENT_EXCLUDED_TOPICS=crypto,nft,giveaway
