# Supabase (required for trend_intelligence_feed writes)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Apify TikTok scraper (required for live TikTok fetch in GitHub Actions / CLI)
APIFY_API_TOKEN=

# Optional Apify overrides
APIFY_TIKTOK_ACTOR_ID=clockworks/tiktok-scraper
APIFY_TIKTOK_CONFIG_PATH=data/apify_tiktok_config.json
TIKTOK_APIFY_HASHTAGS=britishpride,patriotism,ukpolitics,britishhistory,england
TIKTOK_APIFY_SEARCH_QUERIES=British pride TikTok|patriotism UK debate|British veterans respect
TIKTOK_APIFY_RESULTS_PER_PAGE=10

# Optional Supabase table override
SUPABASE_FEED_TABLE=trend_intelligence_feed
